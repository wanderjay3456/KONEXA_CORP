# Runtime
NODE_ENV="development"
PORT=3000
APP_URL="http://localhost:3000"

# Supabase
SUPABASE_URL="https://isrzklwhxdirmgdxgcvs.supabase.co"
SUPABASE_PUBLISHABLE_KEY="sb_publishable_replace_me"
# Server only. Never prefix this with VITE_ and never commit the real value.
SUPABASE_SECRET_KEY="sb_secret_replace_me"

# Optional frontend overrides. The publishable key is safe in a browser when RLS is enabled.
VITE_SUPABASE_URL="https://isrzklwhxdirmgdxgcvs.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_replace_me"

# Google Gemini (server only)
GEMINI_API_KEY="replace_in_secret_manager"

# Stripe subscriptions (server only)
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
STRIPE_PRICE_PRO_MONTHLY="price_replace_me"
STRIPE_ALLOW_TEST_MODE="true"

# Resend transactional email (server only)
RESEND_API_KEY="re_replace_me"
RESEND_WEBHOOK_SECRET="whsec_replace_me"
EMAIL_FROM="KONEXA <notifications@your-verified-domain.com>"
