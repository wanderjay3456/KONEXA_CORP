# Runtime
NODE_ENV="development"
PORT=3000
APP_URL="http://localhost:3000"

# Firebase Admin uses Application Default Credentials on Cloud Run.
FIREBASE_PROJECT_ID="optimum-frame-b3kpg"
FIRESTORE_DATABASE_ID="ai-studio-df84fe4d-6764-4f00-a58a-e280a3ccace6"

# Google Gemini (server only)
GEMINI_API_KEY="replace_in_secret_manager"

# Stripe subscriptions (server only)
STRIPE_SECRET_KEY="sk_test_replace_me"
STRIPE_WEBHOOK_SECRET="whsec_replace_me"
STRIPE_PRICE_PRO_MONTHLY="price_replace_me"
# Never enable this on a public production deployment.
STRIPE_ALLOW_TEST_MODE="true"

# Resend transactional email (server only)
RESEND_API_KEY="re_replace_me"
RESEND_WEBHOOK_SECRET="whsec_replace_me"
EMAIL_FROM="KONEXA <notifications@your-verified-domain.com>"
EMAIL_REPLY_TO="support@your-verified-domain.com"
