rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function owns(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function isCompany() {
      return signedIn() && role() == 'company';
    }

    function isStudent() {
      return signedIn() && role() == 'student';
    }

    match /users/{userId} {
      allow read: if owns(userId) || isAdmin();
      allow create: if owns(userId)
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.role in ['student', 'company'];
      allow update: if isAdmin() || (owns(userId)
        && request.resource.data.role == resource.data.role
        && request.resource.data.uid == resource.data.uid);
      allow delete: if isAdmin();
    }

    match /student_profiles/{userId} {
      allow read: if signedIn();
      allow create, update: if owns(userId) && request.resource.data.uid == request.auth.uid;
      allow delete: if owns(userId) || isAdmin();
    }

    match /company_profiles/{userId} {
      allow read: if signedIn();
      allow create, update: if owns(userId) && request.resource.data.uid == request.auth.uid;
      allow delete: if owns(userId) || isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
    }

    match /verification_requests/{requestId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /projects/{projectId} {
      allow read: if true;
      allow create: if isCompany() && request.resource.data.companyId == request.auth.uid;
      allow update, delete: if isAdmin() || (isCompany() && resource.data.companyId == request.auth.uid);
    }

    match /applications/{applicationId} {
      allow create: if isStudent()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.companyId == get(/databases/$(database)/documents/projects/$(request.resource.data.projectId)).data.companyId;
      allow read: if isAdmin()
        || (signedIn() && resource.data.studentId == request.auth.uid)
        || (isCompany() && resource.data.companyId == request.auth.uid);
      allow update: if isAdmin()
        || (isCompany() && resource.data.companyId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /logs/{logId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /security_logs/{logId} {
      allow read: if isAdmin();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    match /subscriptions/{userId} {
      allow read: if owns(userId) || isAdmin();
      allow write: if false;
    }

    match /billing_customers/{userId} {
      allow read: if owns(userId) || isAdmin();
      allow write: if false;
    }

    match /email_deliveries/{emailId} {
      allow read: if isAdmin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    match /rbac_policies/{policyId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
